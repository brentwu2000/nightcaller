{
  "name": "nightcaller",
  "version": "1.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "deploy": "npm version patch --no-git-tag-version && vue-tsc --noEmit && vite build && npx wrangler pages deploy dist --project-name=cheese-thief",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "dexie": "^3.2.7",
    "howler": "^2.2.4",
    "pinia": "^2.1.7",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@types/howler": "^2.2.11",
    "@vitejs/plugin-vue": "^5.0.4",
    "@vue/test-utils": "^2.4.6",
    "@vitest/coverage-v8": "^1.6.0",
    "fake-indexeddb": "^5.0.2",
    "jsdom": "^24.1.1",
    "typescript": "^5.4.3",
    "vite": "^5.2.6",
    "vite-plugin-pwa": "^0.19.7",
    "vitest": "^1.6.0",
    "vue-tsc": "^2.0.7",
    "workbox-precaching": "^7.0.0",
    "workbox-routing": "^7.0.0"
  }
}
